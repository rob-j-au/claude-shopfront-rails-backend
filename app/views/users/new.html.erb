<div class="container glass-container pt-5 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <!-- Sign Up Card -->
      <div class="glass-card">
        <div class="glass-card-header text-center">
          <h1 class="h3 mb-2 glass-text-white fw-light">
            <i class="bi bi-person-plus me-3"></i>
            Create Account
          </h1>
          <p class="glass-text-muted mb-0">Join our community today</p>
        </div>
        
        <div class="glass-card-body">
          <%= form_with model: @user, local: true do |form| %>
            <% if @user.errors.any? %>
              <div class="glass-alert glass-alert-danger mb-4">
                <div class="d-flex align-items-start">
                  <i class="bi bi-exclamation-triangle me-3 mt-1"></i>
                  <div>
                    <h6 class="glass-text-white mb-2">
                      <%= pluralize(@user.errors.count, "error") %> prohibited this account from being created:
                    </h6>
                    <ul class="mb-0 glass-text-muted small">
                      <% @user.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="row g-3">
              <div class="col-md-6">
                <%= form.label :first_name, class: "form-label" do %>
                  <i class="bi bi-person me-1"></i>
                  First Name
                <% end %>
                <%= form.text_field :first_name, class: "form-control", 
                    placeholder: "Enter your first name" %>
              </div>
              <div class="mb-3">
                <%= form.label :last_name, class: "form-label" do %>
                  <i class="bi bi-person me-1"></i>
                  Last Name
                <% end %>
                <%= form.text_field :last_name, class: "form-control", 
                    placeholder: "Enter your last name" %>
              </div>
              <div class="mb-3">
                <%= form.label :email, class: "form-label" do %>
                  <i class="bi bi-envelope me-1"></i>
                  Email Address
                <% end %>
                <%= form.email_field :email, class: "form-control", 
                    placeholder: "Enter your email address" %>
              </div>

              <div class="mb-3">
                <%= form.label :password, class: "form-label" do %>
                  <i class="bi bi-lock me-1"></i>
                  Password
                <% end %>
                <%= form.password_field :password, class: "form-control", 
                    placeholder: "Create a password", required: true %>
                <small class="form-text text-muted">Password must be at least 6 characters long</small>
              </div>

              <div class="mb-3">
                <%= form.label :password_confirmation, class: "form-label" do %>
                  <i class="bi bi-lock-fill me-1"></i>
                  Confirm Password
                <% end %>
                <%= form.password_field :password_confirmation, class: "form-control", 
                    placeholder: "Confirm your password", required: true %>
              </div>

              <div class="d-grid">
                <%= form.submit "Create Account", class: "btn btn-primary btn-lg" %>
              </div>
            </div>
          <% end %>
        </div>
        
        <div class="glass-card-footer text-center">
          <p class="glass-text-muted mb-0">
            Already have an account? 
            <%= link_to login_path, class: "glass-text-white text-decoration-none" do %>
              <strong>Sign In</strong>
            <% end %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
