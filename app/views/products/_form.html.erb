<%= form_with model: product, local: true do |form| %>
  <% if product.errors.any? %>
    <div class="glass-alert glass-alert-danger mb-4">
      <div class="d-flex align-items-start">
        <i class="bi bi-exclamation-triangle me-3 mt-1"></i>
        <div>
          <h5 class="glass-text-white mb-2">
            <%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:
          </h5>
          <ul class="mb-0 glass-text-muted">
            <% product.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="row g-4">
    <!-- Basic Information -->
    <div class="col-12">
      <h5 class="glass-text-white mb-3 fw-medium">
        <i class="bi bi-info-circle me-2"></i>
        Basic Information
      </h5>
    </div>
    
    <div class="col-md-6">
      <%= form.label :name, class: "form-label" do %>
        <i class="bi bi-tag me-1"></i>
        Product Name
      <% end %>
      <%= form.text_field :name, class: "form-control", placeholder: "Enter product name" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :sku, class: "form-label" do %>
        <i class="bi bi-upc me-1"></i>
        SKU
      <% end %>
      <%= form.text_field :sku, class: "form-control", placeholder: "Enter SKU code" %>
    </div>
    <div class="col-12 mb-3">
      <%= form.label :description, class: "form-label" do %>
        <i class="bi bi-file-text me-1"></i>
        Description
      <% end %>
      <%= form.text_area :description, rows: 4, class: "form-control", 
          placeholder: "Enter product description" %>
    </div>

    <!-- Pricing & Inventory -->
    <div class="col-12 mt-5">
      <h5 class="mb-3 fw-medium">
        <i class="bi bi-currency-dollar me-2"></i>
        Pricing & Inventory
      </h5>
    </div>

    <div class="col-md-6">
      <%= form.label :price, class: "form-label" do %>
        <i class="bi bi-currency-dollar me-1"></i>
        Price
      <% end %>
      <div class="input-group">
        <span class="input-group-text">$</span>
        <%= form.number_field :price, step: 0.01, min: 0, class: "form-control", 
            placeholder: "0.00" %>
      </div>
    </div>

    <div class="col-md-6">
      <%= form.label :stock_quantity, class: "form-label" do %>
        <i class="bi bi-box-seam me-1"></i>
        Stock Quantity
      <% end %>
      <%= form.number_field :stock_quantity, min: 0, class: "form-control", 
          placeholder: "Enter stock quantity" %>
    </div>

    <!-- Category & Status -->
    <div class="col-12 mt-5">
      <h5 class="glass-text-white mb-3 fw-medium">
        <i class="bi bi-gear me-2"></i>
        Category & Status
      </h5>
    </div>

    <div class="col-md-6">
      <%= form.label :category_id, class: "form-label" do %>
        <i class="bi bi-folder me-1"></i>
        Category
      <% end %>
      <%= form.collection_select :category_id, 
                                 Category.active.ordered, 
                                 :id, 
                                 :name, 
                                 { prompt: "Select a category", include_blank: "No category" }, 
                                 { class: "form-select" } %>
    </div>
    
    <div class="col-md-6">
      <div class="form-check mt-4 pt-2">
        <%= form.check_box :active, class: "form-check-input" %>
        <%= form.label :active, "Active Product", class: "form-check-label" %>
        <div class="mt-1">
          <small class="form-text text-muted">Inactive products won't be visible to customers</small>
        </div>
      </div>
    </div>
  </div>
  
  <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
    <%= form.submit class: "btn btn-primary" do %>
      <i class="bi bi-check me-2"></i>
      <%= product.persisted? ? 'Update Product' : 'Create Product' %>
    <% end %>
    <%= link_to products_path, class: "btn btn-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>
      Cancel
    <% end %>
  </div>
</div>
<% end %>
