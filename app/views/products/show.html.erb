<div class="container pt-4 pb-5">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      <!-- Breadcrumb Navigation -->
      <div class="mb-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
          </ol>
        </nav>
      </div>

      <!-- Product Details Card -->
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h1 class="h3 mb-2">
                <i class="bi bi-box me-3"></i>
                <%= @product.name %>
              </h1>
              <% if @product.category %>
                <span class="badge bg-light text-dark">
                  <i class="bi bi-folder me-1"></i>
                  <%= @product.category.name %>
                </span>
              <% end %>
            </div>
            <% if @product.in_stock? %>
              <span class="badge bg-success fs-6">
                <i class="bi bi-check-circle me-1"></i>
                <%= @product.stock_quantity %> in stock
              </span>
            <% else %>
              <span class="badge bg-danger fs-6">
                <i class="bi bi-x-circle me-1"></i>
                Out of Stock
              </span>
            <% end %>
          </div>
        </div>
        
        <div class="card-body">
          <!-- Product Image -->
          <div class="row">
            <div class="col-md-6 mb-4">
              <%= image_tag @product.large_image_url, 
                  alt: @product.name,
                  class: "img-fluid rounded shadow",
                  style: "width: 100%; height: 400px; object-fit: cover;" %>
            </div>
            
            <div class="col-md-6">
              <!-- Product Info -->
              <div class="mb-4">
                <h2 class="h4 mb-3"><%= @product.name %></h2>
                <div class="h3 text-success mb-3"><%= @product.formatted_price %></div>
                <p class="text-muted mb-2"><strong>SKU:</strong> <%= @product.sku %></p>
                <% if @product.category %>
                  <p class="mb-3">
                    <span class="badge bg-secondary">
                      <i class="bi bi-folder me-1"></i>
                      <%= @product.category.name %>
                    </span>
                  </p>
                <% end %>
              </div>
            </div>
          </div>
          
          <!-- Description -->
          <% if @product.description.present? %>
            <div class="mb-4">
              <h5 class="mb-3">
                <i class="bi bi-file-text me-2"></i>
                Description
              </h5>
              <div class="text-muted lh-base">
                <%= simple_format(@product.description) %>
              </div>
            </div>
          <% end %>
          
          <!-- Add to Cart Section -->
          <% if @product.in_stock? %>
            <div class="card border-primary mb-4">
              <div class="card-body">
                <h5 class="card-title text-primary mb-3">
                  <i class="bi bi-cart-plus me-2"></i>
                  Add to Cart
                </h5>
                <%= form_with url: cart_add_path, method: :post, local: true do |form| %>
                  <%= form.hidden_field :product_id, value: @product.id %>
                  <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                      <%= form.label :quantity, class: "form-label" do %>
                        <i class="bi bi-hash me-2"></i>
                        Quantity
                      <% end %>
                      <%= form.number_field :quantity, value: 1, min: 1, max: @product.stock_quantity, 
                          class: "form-control" %>
                    </div>
                    <div class="col-md-8">
                      <%= form.submit "Add to Cart", class: "btn btn-success w-100" %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <div class="alert alert-danger mb-4">
              <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <div>
                  <strong>Out of Stock</strong>
                  <p class="mb-0 mt-1">This product is currently unavailable. Check back later!</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Action Buttons -->
        <div class="card-footer bg-light">
          <div class="d-flex gap-3">
            <%= link_to edit_product_path(@product), class: "btn btn-primary" do %>
              <i class="bi bi-pencil me-2"></i>
              Edit Product
            <% end %>
            <%= link_to products_path, class: "btn btn-secondary" do %>
              <i class="bi bi-arrow-left me-2"></i>
              Back to Products
            <% end %>
            <%= link_to @product, method: :delete, 
                class: "btn btn-danger", 
                confirm: "Are you sure you want to delete this product? This action cannot be undone.",
                data: { turbo_method: :delete } do %>
              <i class="bi bi-trash me-2"></i>
              Delete Product
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
