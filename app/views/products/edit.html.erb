<div class="container glass-container pt-4 pb-5">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <!-- Breadcrumb Navigation -->
      <div class="mb-4">
        <nav aria-label="breadcrumb">
          <ol class="glass-breadcrumb breadcrumb mb-0">
            <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
            <li class="breadcrumb-item"><%= link_to @product.name, product_path(@product) %></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
          </ol>
        </nav>
      </div>

      <!-- Edit Product Card -->
      <div class="glass-card">
        <div class="glass-card-header">
          <h1 class="h3 mb-0 glass-text-white fw-light">
            <i class="bi bi-pencil me-3"></i>
            Edit Product
          </h1>
          <p class="glass-text-muted mb-0 mt-2">Update product information and settings</p>
        </div>
        
        <div class="glass-card-body">
          <%= render 'form', product: @product %>
        </div>
      </div>
    </div>
  </div>
</div>
