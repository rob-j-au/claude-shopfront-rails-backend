<div class="container glass-container pt-5 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
      <!-- Login Card -->
      <div class="glass-card">
        <div class="glass-card-header text-center">
          <h1 class="h3 mb-2 glass-text-white fw-light">
            <i class="bi bi-box-arrow-in-right me-3"></i>
            Welcome Back
          </h1>
          <p class="text-muted mb-0">Sign in to your account</p>
        </div>
        
        <div class="card-body">
          <%= form_with url: login_path, method: :post, local: true do |form| %>
            <div class="mb-4">
              <%= form.label :email, class: "form-label" do %>
                <i class="bi bi-envelope me-1"></i>
                Email Address
              <% end %>
              <%= form.email_field :email, class: "form-control", 
                  placeholder: "Enter your email address", required: true %>
            </div>
            
            <div class="mb-4">
              <%= form.label :password, class: "form-label" do %>
                <i class="bi bi-lock me-1"></i>
                Password
              <% end %>
              <%= form.password_field :password, class: "form-control", 
                  placeholder: "Enter your password", required: true %>
            </div>
            
            <div class="d-grid">
              <%= form.submit "Sign In", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
        
        <div class="card-footer text-center">
          <p class="text-muted mb-0">
            Don't have an account? 
            <%= link_to signup_path, class: "glass-text-white text-decoration-none" do %>
              <strong>Create Account</strong>
            <% end %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
