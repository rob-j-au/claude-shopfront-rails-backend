<div class="container mt-4">
  <% if notice %>
    <div class="alert alert-success mb-4" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-check-circle me-2"></i>
        <%= notice %>
      </div>
    </div>
  <% end %>

  <div class="row">
    <div class="col-lg-8 mx-auto">
      <div class="mb-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Categories", categories_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @category.name %></li>
          </ol>
        </nav>
      </div>

      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <div class="d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">
              <i class="bi bi-folder me-3"></i>
              <%= @category.name %>
            </h1>
            <% if @category.active %>
              <span class="badge bg-success fs-6">
                <i class="bi bi-check-circle me-1"></i>
                Active
              </span>
            <% else %>
              <span class="badge bg-secondary fs-6">
                <i class="bi bi-pause-circle me-1"></i>
                Inactive
              </span>
            <% end %>
          </div>
        </div>
        
        <div class="card-body">
          <% if @category.description.present? %>
            <div class="mb-4">
              <h5 class="mb-3">
                <i class="bi bi-file-text me-2"></i>
                Description
              </h5>
              <div class="text-muted">
                <%= simple_format(@category.description) %>
              </div>
            </div>
          <% end %>
          
          <div class="row">
            <div class="col-sm-6 mb-4">
              <div class="d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" 
                     style="width: 48px; height: 48px;">
                  <i class="bi bi-box-seam text-primary fs-5"></i>
                </div>
                <div>
                  <h5 class="mb-1">Products</h5>
                  <% products_count = @category.products.count %>
                  <p class="text-muted mb-0">
                    <%= pluralize(products_count, 'product') %>
                  </p>
                </div>
              </div>
            </div>
            <div class="col-sm-6 mb-4">
              <div class="d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center me-3" 
                     style="width: 48px; height: 48px;">
                  <i class="bi bi-calendar text-info fs-5"></i>
                </div>
                <div>
                  <h5 class="mb-1">Created</h5>
                  <p class="text-muted mb-0">
                    <%= @category.created_at.strftime("%B %d, %Y") %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Products Section -->
        <% if @products.any? %>
          <div class="card-footer bg-light border-top">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h4 class="mb-0">
                <i class="bi bi-grid-3x3-gap me-2"></i>
                Products in this Category
                <span class="badge bg-primary ms-2"><%= @total_count %></span>
              </h4>
              <% if @total_pages > 1 %>
                <small class="text-muted">
                  Page <%= @current_page %> of <%= @total_pages %>
                </small>
              <% end %>
            </div>
            
            <!-- Products Grid -->
            <div class="row" id="products-list">
              <%= render partial: 'products/product_card', collection: @products, as: :product %>
            </div>
            
            <!-- Pagination -->
            <% if @total_pages > 1 %>
              <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Products pagination">
                  <ul class="pagination">
                    <!-- Previous Page -->
                    <% if @current_page > 1 %>
                      <li class="page-item">
                        <%= link_to category_path(@category, page: @current_page - 1), class: "page-link" do %>
                          <i class="bi bi-chevron-left"></i>
                          Previous
                        <% end %>
                      </li>
                    <% else %>
                      <li class="page-item disabled">
                        <span class="page-link">
                          <i class="bi bi-chevron-left"></i>
                          Previous
                        </span>
                      </li>
                    <% end %>
                    
                    <!-- Page Numbers -->
                    <% start_page = [@current_page - 2, 1].max %>
                    <% end_page = [start_page + 4, @total_pages].min %>
                    <% start_page = [end_page - 4, 1].max if end_page - start_page < 4 %>
                    
                    <% (start_page..end_page).each do |page| %>
                      <% if page == @current_page %>
                        <li class="page-item active">
                          <span class="page-link"><%= page %></span>
                        </li>
                      <% else %>
                        <li class="page-item">
                          <%= link_to page, category_path(@category, page: page), class: "page-link" %>
                        </li>
                      <% end %>
                    <% end %>
                    
                    <!-- Next Page -->
                    <% if @has_next_page %>
                      <li class="page-item">
                        <%= link_to category_path(@category, page: @current_page + 1), class: "page-link" do %>
                          Next
                          <i class="bi bi-chevron-right"></i>
                        <% end %>
                      </li>
                    <% else %>
                      <li class="page-item disabled">
                        <span class="page-link">
                          Next
                          <i class="bi bi-chevron-right"></i>
                        </span>
                      </li>
                    <% end %>
                  </ul>
                </nav>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="card-footer bg-light border-top text-center py-4">
            <div class="text-muted">
              <i class="bi bi-inbox display-4 d-block mb-3"></i>
              <h5>No Products Found</h5>
              <p class="mb-3">This category doesn't have any active products yet.</p>
              <%= link_to new_product_path(category: @category.name), class: "btn btn-primary" do %>
                <i class="bi bi-plus-circle me-2"></i>
                Add First Product
              <% end %>
            </div>
          </div>
        <% end %>
        
        <div class="card-footer bg-light border-top">
          <div class="d-flex gap-2 justify-content-end">
            <%= link_to edit_category_path(@category), class: "btn btn-primary" do %>
              <i class="bi bi-pencil me-2"></i>
              Edit Category
            <% end %>
            <%= link_to categories_path, class: "btn btn-secondary" do %>
              <i class="bi bi-arrow-left me-2"></i>
              Back to Categories
            <% end %>
            <%= button_to @category, method: :delete, 
                class: "btn btn-danger", 
                confirm: "Are you sure you want to delete this category? This action cannot be undone.",
                data: { 
                  turbo_method: :delete
                } do %>
              <i class="bi bi-trash me-2"></i>
              Delete Category
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
