<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Shopfront App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Bootstrap CSS %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <%# Bootstrap JS %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </head>

  <body class="glass-background">
    <!-- Glass Navigation Bar -->
    <nav class="navbar navbar-expand-lg fixed-top" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.2);">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand glass-text-white fw-bold" do %>
          <i class="bi bi-shop me-2"></i>
          Shopfront
        <% end %>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                style="border: 1px solid rgba(255, 255, 255, 0.3); background: rgba(255, 255, 255, 0.1);">
          <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to products_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                  style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                <i class="bi bi-grid-3x3-gap me-2"></i>
                Products
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to categories_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                  style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                <i class="bi bi-folder me-2"></i>
                Categories
              <% end %>
            </li>
          </ul>
          
          <ul class="navbar-nav">
            <li class="nav-item">
              <%= link_to cart_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                  style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                <i class="bi bi-cart me-2"></i>
                Cart (<%= cart_item_count %>)
              <% end %>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to orders_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                    style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                  <i class="bi bi-receipt me-2"></i>
                  Orders
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to current_user, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                    style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                  <i class="bi bi-person me-2"></i>
                  Profile
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to destroy_user_session_path, method: :delete, 
                    class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                    style: "transition: all 0.3s ease; background: rgba(255, 59, 48, 0.3);" do %>
                  <i class="bi bi-box-arrow-right me-2"></i>
                  Logout
                <% end %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to new_user_session_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                    style: "transition: all 0.3s ease; background: rgba(255, 255, 255, 0.1);" do %>
                  <i class="bi bi-box-arrow-in-right me-2"></i>
                  Login
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to new_user_registration_path, class: "nav-link glass-text-white px-3 py-2 rounded-pill mx-1", 
                    style: "transition: all 0.3s ease; background: rgba(0, 122, 255, 0.4);" do %>
                  <i class="bi bi-person-plus me-2"></i>
                  Sign Up
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content with Glass Styling -->
    <main class="glass-container" style="padding-top: 100px; min-height: 100vh;">
      <% if notice %>
        <div class="container mb-4">
          <div class="glass-alert glass-alert-success" role="alert">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle me-2"></i>
              <%= notice %>
            </div>
          </div>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="container mb-4">
          <div class="glass-alert glass-alert-danger" role="alert">
            <div class="d-flex align-items-center">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <%= alert %>
            </div>
          </div>
        </div>
      <% end %>
      
      <%= yield %>
    </main>

    <!-- Add hover effects for navigation -->
    <style>
      .nav-link:hover {
        background: rgba(255, 255, 255, 0.2) !important;
        transform: translateY(-1px);
      }
      
      .navbar-brand:hover {
        transform: scale(1.05);
        transition: transform 0.3s ease;
      }
      
      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }
    </style>
  </body>
</html>
