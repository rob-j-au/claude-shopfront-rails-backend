<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">
          <i class="fas fa-shopping-bag me-2 text-primary"></i>
          My Orders
        </h1>
        <div class="text-muted">
          <i class="fas fa-box me-1"></i>
          <%= @orders.count %> <%= @orders.count == 1 ? 'order' : 'orders' %>
        </div>
      </div>
    </div>
  </div>

  <% if @orders.any? %>
    <div class="row">
      <div class="col-12">
        <% @orders.each do |order| %>
          <div class="card mb-4 shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
              <div class="row align-items-center">
                <div class="col-md-6">
                  <h5 class="mb-0 fw-bold text-dark">
                    <i class="fas fa-receipt me-2 text-muted"></i>
                    Order <%= order.order_number %>
                  </h5>
                </div>
                <div class="col-md-6 text-md-end">
                  <span class="badge fs-6 px-3 py-2 bg-<%= order.status == 'delivered' ? 'success' : order.status == 'cancelled' ? 'danger' : order.status == 'processing' ? 'warning' : 'primary' %>">
                    <i class="fas fa-<%= order.status == 'delivered' ? 'check-circle' : order.status == 'cancelled' ? 'times-circle' : order.status == 'processing' ? 'clock' : 'hourglass-start' %> me-1"></i>
                    <%= order.status.titleize %>
                  </span>
                </div>
              </div>
            </div>
            
            <div class="card-body">
              <div class="row">
                <div class="col-lg-8">
                  <div class="row g-3">
                    <div class="col-sm-6">
                      <div class="d-flex align-items-center">
                        <i class="fas fa-calendar-alt text-muted me-2"></i>
                        <div>
                          <small class="text-muted d-block">Order Date</small>
                          <span class="fw-medium"><%= order.created_at.strftime("%B %d, %Y") %></span>
                          <small class="text-muted d-block"><%= order.created_at.strftime("%I:%M %p") %></small>
                        </div>
                      </div>
                    </div>
                    
                    <div class="col-sm-3">
                      <div class="d-flex align-items-center">
                        <i class="fas fa-dollar-sign text-success me-2"></i>
                        <div>
                          <small class="text-muted d-block">Total Amount</small>
                          <span class="fw-bold text-success fs-5"><%= order.formatted_total_amount %></span>
                        </div>
                      </div>
                    </div>
                    
                    <div class="col-sm-3">
                      <div class="d-flex align-items-center">
                        <i class="fas fa-shopping-cart text-primary me-2"></i>
                        <div>
                          <small class="text-muted d-block">Items</small>
                          <span class="fw-medium"><%= order.line_items.count %> <%= order.line_items.count == 1 ? 'item' : 'items' %></span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="col-lg-4">
                  <div class="d-flex flex-column gap-2 h-100 justify-content-center">
                    <%= link_to order, class: "btn btn-primary d-flex align-items-center justify-content-center" do %>
                      <i class="fas fa-eye me-2"></i>
                      View Details
                    <% end %>
                    
                    <% if order.can_be_cancelled? %>
                      <%= form_with model: order, url: order_path(order), method: :patch, local: true, authenticity_token: true, class: "w-100" do |form| %>
                        <%= form.hidden_field :action_type, value: 'cancel' %>
                        <%= form.submit "Cancel Order", class: "btn btn-outline-danger d-flex align-items-center justify-content-center w-100", 
                                        data: { confirm: "Are you sure you want to cancel this order?" } do %>
                          <i class="fas fa-times me-2"></i>
                          Cancel Order
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="text-center py-5">
          <div class="mb-4">
            <i class="fas fa-shopping-bag fa-4x text-muted"></i>
          </div>
          <h3 class="text-muted mb-3">No Orders Yet</h3>
          <p class="text-muted mb-4">You haven't placed any orders yet. Start shopping to see your orders here!</p>
          <%= link_to products_path, class: "btn btn-primary btn-lg d-inline-flex align-items-center" do %>
            <i class="fas fa-shopping-cart me-2"></i>
            Start Shopping
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
