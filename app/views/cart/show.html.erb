<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <!-- Page Header -->
      <div class="mb-4">
        <h1 class="h3">
          <i class="bi bi-cart me-3"></i>
          Shopping Cart
        </h1>
      </div>

      <% if @cart_items.any? %>
        <div class="row">
          <!-- Cart Items -->
          <div class="col-lg-8 mb-4">
            <% @cart_items.each do |item| %>
              <div class="card mb-3 shadow-sm">
                <div class="card-body">
                  <div class="row align-items-center">
                    <!-- Product Image -->
                    <div class="col-md-2 mb-3">
                      <div class="position-relative">
                        <%= image_tag item[:product].thumbnail_url(size: 80), 
                            alt: item[:product].name,
                            class: "w-100 rounded-3",
                            style: "height: 80px; object-fit: cover;" %>
                      </div>
                    </div>
                    
                    <!-- Product Info -->
                    <div class="col-md-4 mb-3">
                      <h6 class="mb-2">
                        <%= item[:product].name %>
                      </h6>
                      <p class="text-muted mb-1 small">
                        <i class="bi bi-currency-dollar me-1"></i>
                        <%= item[:product].formatted_price %> each
                      </p>
                      <% if item[:product].category %>
                        <span class="badge bg-secondary small">
                          <i class="bi bi-folder me-1"></i>
                          <%= item[:product].category.name %>
                        </span>
                      <% end %>
                      <div class="text-muted small mt-1">
                        <i class="bi bi-upc me-1"></i>
                        SKU: <%= item[:product].sku %>
                      </div>
                    </div>
                    
                    <div class="col-md-3 mb-2">
                      <%= form_with url: cart_update_path, method: :patch, local: true, class: "d-flex align-items-center" do |form| %>
                        <%= form.hidden_field :product_id, value: item[:product].id %>
                        <div class="me-2">
                          <%= form.number_field :quantity, value: item[:quantity], min: 1, max: item[:product].stock_quantity, 
                              class: "form-control text-center", style: "width: 80px;" %>
                        </div>
                        <%= form.submit "Update", class: "btn btn-outline-secondary btn-sm" %>
                      <% end %>
                    </div>
                    
                    <div class="col-md-2 mb-2">
                      <div class="text-center">
                        <p class="text-muted small mb-1">Subtotal</p>
                        <h6 class="fw-bold mb-0 text-success">
                          <%= "$#{'%.2f' % item[:total]}" %>
                        </h6>
                      </div>
                    </div>
                    
                    <div class="col-md-1">
                      <%= link_to cart_remove_path(product_id: item[:product].id), method: :delete, 
                                  confirm: "Remove this item from your cart?", 
                                  class: "btn btn-outline-danger btn-sm" do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          
          <!-- Order Summary -->
          <div class="col-lg-4">
            <div class="card shadow sticky-top" style="top: 2rem;">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                  <i class="bi bi-receipt me-2"></i>
                  Order Summary
                </h5>
              </div>
              
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                  <span class="text-muted">Total Amount:</span>
                  <h4 class="fw-bold mb-0 text-success">
                    <%= "$#{'%.2f' % @total}" %>
                  </h4>
                </div>
                
                <div class="mb-3">
                  <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    <%= pluralize(@cart_items.sum { |item| item[:quantity] }, 'item') %> in cart
                  </small>
                </div>
                
                <% if user_signed_in? %>
                  <%= form_with url: orders_path, method: :post, local: true, class: "mb-3" do |form| %>
                    <%= form.submit "Place Order", class: "btn btn-success w-100" do %>
                      <i class="bi bi-check-circle me-2"></i>
                      Place Order
                    <% end %>
                  <% end %>
                <% else %>
                  <div class="alert alert-info mb-3">
                    <div class="d-flex align-items-center">
                      <i class="bi bi-info-circle me-2"></i>
                      <div>
                        <strong>Login Required</strong>
                        <p class="mb-0 mt-1 small">Please sign in to place your order</p>
                      </div>
                    </div>
                  </div>
                  <%= link_to login_path, class: "btn btn-primary w-100 mb-3" do %>
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    Sign In to Place Order
                  <% end %>
                  <div class="text-center">
                    <small class="text-muted">or</small>
                  </div>
                  <%= button_to cart_clear_path, method: :delete, 
                      class: "btn btn-danger w-100" do %>
                    <i class="bi bi-trash me-2"></i>
                    Clear Cart
                  <% end %>
                <% end %>
                
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Empty Cart State -->
        <div class="row justify-content-center">
          <div class="col-md-6">
            <div class="glass-card text-center">
              <div class="glass-card-body py-5">
                <div class="mb-4">
                  <i class="bi bi-cart-x glass-text-muted" style="font-size: 4rem;"></i>
                </div>
                <h4 class="glass-text-white mb-3 fw-light">Your cart is empty</h4>
                <p class="glass-text-muted mb-4">Discover amazing products and start building your perfect order!</p>
                <%= link_to products_path, class: "btn btn-primary" do %>
                  <i class="bi bi-arrow-left me-2"></i>
                  Continue Shopping
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
