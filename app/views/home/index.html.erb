<div class="container glass-container pt-4 pb-5">
  <!-- Hero Section -->
  <div class="glass-card mb-5">
    <div class="glass-card-body text-center py-5">
      <div class="mb-4">
        <i class="bi bi-shop" style="font-size: 4rem; color: rgba(255, 255, 255, 0.8);"></i>
      </div>
      <h1 class="display-4 glass-text-white fw-light mb-4">Welcome to Shopfront</h1>
      <p class="lead glass-text-muted mb-4">Discover amazing products at great prices with our premium shopping experience</p>
      <div class="d-flex gap-3 justify-content-center">
        <%= link_to products_path, class: "btn btn-primary" do %>
          <i class="bi bi-grid me-2"></i>
          Browse Products
        <% end %>
        <%= link_to categories_path, class: "btn btn-secondary" do %>
          <i class="bi bi-folder me-2"></i>
          View Categories
        <% end %>
      </div>
    </div>
  </div>

  <!-- Featured Products Section -->
  <div class="mb-4">
    <h2 class="glass-text-white fw-light mb-4">
      <i class="bi bi-star me-3"></i>
      Featured Products
    </h2>
  </div>

  <div class="row">
    <% if @featured_products.any? %>
      <% @featured_products.each do |product| %>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm border-warning">
            <!-- Featured Product Image -->
            <%= image_tag product.image_url(width: 400, height: 220), 
                alt: product.name,
                class: "card-img-top",
                style: "height: 180px; object-fit: cover;" %>
            
            <div class="card-body d-flex flex-column">
              <!-- Featured Badge -->
              <div class="mb-2">
                <span class="badge bg-warning text-dark">
                  <i class="bi bi-star-fill me-1"></i>
                  Featured
                </span>
                <% if product.category %>
                  <span class="badge bg-secondary ms-2">
                    <i class="bi bi-folder me-1"></i>
                    <%= product.category.name %>
                  </span>
                <% end %>
              </div>
              
              <!-- Product Info -->
              <h5 class="card-title"><%= product.name %></h5>
              <div class="h5 text-success mb-3"><%= product.formatted_price %></div>
              
              <% if product.description.present? %>
                <p class="card-text text-muted mb-3"><%= truncate(product.description, length: 80) %></p>
              <% else %>
                <p class="card-text text-muted fst-italic mb-3">No description available</p>
              <% end %>
              
              <!-- Stock Status -->
              <div class="mb-3">
                <% if product.in_stock? %>
                  <span class="badge bg-success">
                    <i class="bi bi-check-circle me-1"></i>
                    In Stock
                  </span>
                <% else %>
                  <span class="badge bg-danger">
                    <i class="bi bi-x-circle me-1"></i>
                    Out of Stock
                  </span>
                <% end %>
              </div>
              
              <!-- Action Buttons -->
              <div class="mt-auto">
                <div class="d-grid gap-2">
                  <%= link_to product, class: "btn btn-outline-primary" do %>
                    <i class="bi bi-eye me-2"></i>
                    View Details
                  <% end %>
                  <% if product.in_stock? %>
                    <%= form_with url: cart_add_path, method: :post, local: true do |form| %>
                      <%= form.hidden_field :product_id, value: product.id %>
                      <%= form.hidden_field :quantity, value: 1 %>
                      <%= form.submit "Add to Cart", class: "btn btn-success w-100" %>
                    <% end %>
                  <% else %>
                    <button class="btn btn-secondary w-100" disabled>
                      <i class="bi bi-cart-x me-2"></i>
                      Out of Stock
                    </button>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <div class="text-center py-5">
          <div class="glass-card p-5">
            <div class="mb-4">
              <i class="bi bi-box-seam" style="font-size: 4rem; color: rgba(255, 255, 255, 0.4);"></i>
            </div>
            <h3 class="glass-text-white mb-3 fw-light">No Products Available</h3>
            <p class="glass-text-muted mb-4">Check back later for new products or help us get started!</p>
            <%= link_to products_path, class: "btn btn-primary" do %>
              <i class="bi bi-arrow-right me-2"></i>
              View All Products
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
